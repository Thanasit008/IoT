# =========================
# Server
# =========================
PORT=3000

# จำกัด origin ที่ dashboard จะเชื่อม socket.io ได้ (เว้นว่าง = "*" อนุญาตทุกที่ ไม่แนะนำใน production)
FRONTEND_URL=

# =========================
# MQTT Broker
# =========================
MQTT_HOST=your-broker-host
MQTT_PORT=8883
MQTT_USER=your-mqtt-username
MQTT_PASS=your-mqtt-password

# true เมื่อ broker ใช้ certificate ที่ถูกต้อง (เช่น HiveMQ Cloud, EMQX Cloud)
# false ใช้เฉพาะตอน dev ด้วย self-signed cert เท่านั้น เสี่ยงต่อ MITM ถ้าใช้ใน production
MQTT_REJECT_UNAUTHORIZED=true

# =========================
# Device Access (ไม่มีระบบ Login/User — ใช้ไอดีเครื่อง + รหัสแทน)
# ตั้งค่าคู่นี้แล้วให้ผู้ใช้กรอกที่หน้าเว็บก่อนเข้าถึง Dashboard/API
# =========================
DEVICE_ID=fishfeeder01
DEVICE_CODE=change-this-to-a-long-random-code
